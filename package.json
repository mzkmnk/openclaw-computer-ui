{
  "name": "openclaw-computer-ui",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "api:dev": "pnpm -C packages/api dev",
    "api:build": "pnpm -C packages/api build",
    "api:start": "pnpm -C packages/api start",
    "format": "prettier --write \"{packages,.github}/**/*.{ts,tsx,js,mjs,json,yml,yaml}\" \"*.{json,yml,yaml,mjs}\"",
    "format:check": "prettier --check \"{packages,.github}/**/*.{ts,tsx,js,mjs,json,yml,yaml}\" \"*.{json,yml,yaml,mjs}\""
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
